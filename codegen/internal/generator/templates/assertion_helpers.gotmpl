{{ template "header" . }}

package {{ .Package }}

{{- if .Imports.HasImports }}

import (
{{ imports .Imports }}
)
{{- end }}

{{- range .Functions.Scope "only-helpers" . }} 

{{ comment .DocString }}
func {{ .Name }}({{ params .AllParams }}) {{ returns .Returns }} {
  return {{ .TargetPackage }}.{{ .Name }}({{ forward .AllParams }})
}
{{- end }}
